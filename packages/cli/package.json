{
  "name": "@ossl/pylon-cli",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "bin": {
    "pylon": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@ossl/pylon-core": "workspace:*",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^4.1.8",
    "@types/node": "^25.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
