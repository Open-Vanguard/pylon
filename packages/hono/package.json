{
  "name": "@pylon/hono",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shadow": {
      "types": "./dist/shadow.d.ts",
      "import": "./dist/shadow.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@pylon/core": "workspace:*"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^4.1.8",
    "hono": "^4.12.25",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
